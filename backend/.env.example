# Vision Technologies CRM - Backend environment variables
# Copy this file to .env and edit values for your machine.

SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/vision_crm?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=crm_user
SPRING_DATASOURCE_PASSWORD=crm_pass

JWT_SECRET=ChangeMeToAVeryLongRandomBase64SecretAtLeast64Chars0123456789ABCDEF
JWT_EXPIRATION_MS=86400000

CORS_ALLOWED_ORIGINS=http://localhost:5173

SERVER_PORT=8080
