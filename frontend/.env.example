# Vision Technologies CRM - Frontend environment variables
# Copy this file to .env.

# Base URL of the Spring Boot REST API.
# Inside Docker network, NGINX proxies /api to the backend container,
# so the production value is simply '/api'.
VITE_API_BASE_URL=/api

# Optional: used by vite dev-server proxy during 'npm run dev'.
VITE_API_PROXY=http://localhost:8080
